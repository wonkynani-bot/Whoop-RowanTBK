# Whoop OAuth
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=https://YOUR-DOMAIN.vercel.app/api/whoop-callback

# Also exposed to the browser for the Connect button
NEXT_PUBLIC_WHOOP_CLIENT_ID=your_whoop_client_id

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Cron job security (any random string — generate with: openssl rand -hex 32)
CRON_SECRET=your_cron_secret
